# =============================================================================
# DESENVOLVIMENTO LOCAL — copie:  copy .env.example .env
# Opcional: sem .env o Docker usa os padroes do docker-compose.yml
# =============================================================================

POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespw
POSTGRES_PORT=5432

BACKEND_PORT=8080
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8080
VITE_FINANCEIRO_API_URL=http://localhost:8081
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
APP_FRONTEND_URL=http://localhost:5173

# Remova a linha JWT_SECRET abaixo para usar o padrao do Docker (dev).
# Se definir, use Base64 com 32+ bytes (senao login falha com WeakKeyException).
# JWT_SECRET=

# Chave AES-256 (32 bytes em Base64). Remova a linha para usar o padrao do Docker (dev).
# Gerar nova: openssl rand -base64 32
# CRYPTO_SECRET_KEY=

# Consulta de JWT revogado (Financeiro/Fiscal → Core). Padrao Docker: http://backend:8080/internal/auth/token/blacklist/check
# CORE_BLACKLIST_URL=

APP_ADMIN_EMAIL=admin@odonto.com
APP_ADMIN_PASSWORD=123456

# Recuperacao de senha: em dev, false grava o link no log do backend.
APP_MAIL_ENABLED=false
APP_MAIL_FROM=no-reply@odontohelp.local
SPRING_MAIL_HOST=localhost
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=false
SPRING_MAIL_SMTP_STARTTLS=false

# =============================================================================
# OdontoHelp-Fiscal (porta 8082) — DB dedicado, nao compartilhar com Core
# =============================================================================
FISCAL_PORT=8082
FISCAL_DB_USER=postgres
FISCAL_DB_PASS=

# Mesmo JWT_SECRET do Core e Financeiro
# JWT_SECRET=

# MANUAL = usuario emite no OXY e registra numero
# AUTOMATICO = sistema assina e envia automaticamente (requer certificado)
FISCAL_MODO_EMISSAO=MANUAL

# Dados do emissor — confirmar com contador (nunca commitar valores reais).
# Em dev local/Docker, o padrao e CNPJ ficticio 12345678000199 se nao definir abaixo.
# FISCAL_EMISSOR_CNPJ=12345678000199
# FISCAL_EMISSOR_RAZAO_SOCIAL=OdontoHelp Clinica Dev
FISCAL_EMISSOR_CNPJ=
FISCAL_EMISSOR_RAZAO_SOCIAL=
FISCAL_EMISSOR_INSCRICAO_MUNICIPAL=
FISCAL_EMISSOR_CODIGO_MUNICIPIO=
FISCAL_EMISSOR_CODIGO_SERVICO=
FISCAL_EMISSOR_ALIQUOTA_ISS=
FISCAL_EMISSOR_REGIME_TRIBUTARIO=

# Endereco do emissor
FISCAL_EMISSOR_LOGRADOURO=
FISCAL_EMISSOR_NUMERO=
FISCAL_EMISSOR_BAIRRO=
FISCAL_EMISSOR_CEP=

# Portal OXY (modo MANUAL) e webservice Elotech (modo AUTOMATICO)
# Deixe vazio em dev se ainda nao tiver acesso ao portal — o fluxo "Registrar nº" funciona sem o link.
# NAO use https://openid.oxy.elotech.com.br (e so login OpenID).
# Exemplo Douradina MS:
# FISCAL_PORTAL_OXY_URL=https://douradina.oxy.elotech.com.br/iss
# FISCAL_EMISSOR_CODIGO_MUNICIPIO=5003504
# FISCAL_ELOTECH_URL=https://douradina.oxy.elotech.com.br/iss-ws/nfseService
FISCAL_PORTAL_OXY_URL=
# Webservice SOAP (modo AUTOMATICO), ex.: https://<cidade>.oxy.elotech.com.br/iss-ws/nfseService
FISCAL_ELOTECH_URL=

# Certificado A1 — preencher apenas no modo AUTOMATICO
FISCAL_CERT_PATH=./certs/certificado.pfx
FISCAL_CERT_SENHA=

# Integracao Financeiro → Fiscal (emissao apos pagamento confirmado)
FINANCEIRO_FISCAL_API_URL=http://localhost:8082
FINANCEIRO_FISCAL_ENABLED=true
# Deve coincidir com FISCAL_EMISSOR_CNPJ (padrao dev: 12345678000199)
# FINANCEIRO_FISCAL_TENANT_ID=12345678000199
FINANCEIRO_FISCAL_TENANT_ID=
FINANCEIRO_FISCAL_PORTAL_URL=
