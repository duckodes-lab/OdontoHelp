# =============================================================================
# PRODUCAO (VPS Oracle) — no servidor:  cp .env.production.example .env
# Preencha TUDO antes de subir. Nunca commite o .env do servidor.
#
# Subir:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#
# Pos-incidente / pentest: rotacione JWT_SECRET, POSTGRES_PASSWORD e
# APP_ADMIN_PASSWORD; veja docs/vps-oracle-hardening.md e scripts/vps/
# =============================================================================

POSTGRES_DB=odontohelp
POSTGRES_USER=odontohelp
POSTGRES_PASSWORD=GERE_SENHA_FORTE_POSTGRES

# Postgres NAO fica exposto na VPS (compose prod remove ports)
# POSTGRES_PORT nao precisa

# DuckDNS: crie 3 subdominios apontando para o IP da VPS
FRONTEND_DOMAIN=odontohelp.duckdns.org
API_DOMAIN=api-odontohelp.duckdns.org
FINANCEIRO_API_DOMAIN=financeiro-api-odontohelp.duckdns.org

# URL que o navegador usa para chamar a API (build do frontend + CORS)
VITE_API_URL=https://api-odontohelp.duckdns.org
VITE_FINANCEIRO_API_URL=https://financeiro-api-odontohelp.duckdns.org
CORS_ORIGINS=https://odontohelp.duckdns.org
APP_FRONTEND_URL=https://odontohelp.duckdns.org

# Obrigatorio em producao (PowerShell para gerar):
# [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
JWT_SECRET=GERE_BASE64_AQUI

# Chave AES-256 — gerar com: openssl rand -base64 32
CRYPTO_SECRET_KEY=GERE_BASE64_AQUI

# Financeiro/Fiscal consultam revogacao de JWT no Core (rede Docker interna)
CORE_BLACKLIST_URL=http://backend:8080/internal/auth/token/blacklist/check

APP_ADMIN_EMAIL=seu-email-admin@dominio.com
APP_ADMIN_PASSWORD=GERE_SENHA_FORTE_ADMIN
APP_ADMIN_NAME=ADMINISTRADOR MASTER
APP_ADMIN_PHONE=11999999999
# Opcional. Se preencher, use apenas numeros.
APP_ADMIN_CPF=

# SMTP para recuperacao de senha
APP_MAIL_ENABLED=true
APP_MAIL_FROM=no-reply@seudominio.com
SPRING_MAIL_HOST=smtp.seudominio.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=usuario_smtp
SPRING_MAIL_PASSWORD=senha_smtp
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS=true

# MinIO (armazenamento de arquivos — self-hosted, sem custo de cloud)
MINIO_ROOT_USER=GERE_USUARIO_MINIO
MINIO_ROOT_PASSWORD=GERE_SENHA_FORTE_MINIO
STORAGE_ENDPOINT=http://minio:9000
# Opcional: endpoint publico do MinIO para presigned URLs (dev). Em prod o front usa proxy autenticado.
STORAGE_PUBLIC_ENDPOINT=
STORAGE_ACCESS_KEY=GERE_USUARIO_MINIO
STORAGE_SECRET_KEY=GERE_SENHA_FORTE_MINIO
STORAGE_BUCKET=odontohelp

# =============================================================================
# Fiscal / NFS-e (Douradina MS — ajuste CNPJ e dados reais da clinica)
# Certificado .pfx: copie para certs/fiscal/ na VPS (fora do git)
# =============================================================================
FISCAL_EMISSOR_CNPJ=00000000000000
FISCAL_EMISSOR_RAZAO_SOCIAL=RAZAO SOCIAL DA CLINICA
FISCAL_EMISSOR_INSCRICAO_MUNICIPAL=
FISCAL_EMISSOR_CODIGO_MUNICIPIO=5003504
FISCAL_EMISSOR_CODIGO_SERVICO=
FISCAL_EMISSOR_ALIQUOTA_ISS=
FISCAL_EMISSOR_REGIME_TRIBUTARIO=
FISCAL_EMISSOR_LOGRADOURO=
FISCAL_EMISSOR_NUMERO=
FISCAL_EMISSOR_BAIRRO=
FISCAL_EMISSOR_CEP=
FISCAL_MODO_EMISSAO=MANUAL
FISCAL_PORTAL_OXY_URL=https://douradina.oxy.elotech.com.br/iss
FISCAL_ELOTECH_URL=https://douradina.oxy.elotech.com.br/iss-ws/nfseService
FISCAL_CERT_SENHA=GERE_SENHA_CERTIFICADO

FINANCEIRO_FISCAL_ENABLED=true
FINANCEIRO_FISCAL_TENANT_ID=
